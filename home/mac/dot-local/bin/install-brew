# Docker Desktop casks (docker, docker-desktop) are intentionally left out;
# this machine uses Colima instead (see install-colima).
casks=(
	adobe-acrobat-reader
	anaconda
	audacity
	chromedriver
	claude-code@latest
	commander-one
	dotnet-sdk
	dotnet-sdk10
	dotnet-sdk10-0-300
	dotnet-sdk6-0-400
	dotnet-sdk7-0-100
	dotnet-sdk8-0-100
	firefox
	font-dejavu
	font-fontawesome
	font-inria-sans
	font-inter
	font-jetbrains-mono
	font-latin-modern
	font-latin-modern-math
	font-monaspace
	font-poppins
	font-source-sans-3
	font-tex-gyre-heros
	font-tex-gyre-pagella
	font-tex-gyre-pagella-math
	font-tex-gyre-schola
	font-work-sans
	gimp
	inkscape
	karabiner-elements
	kdiff3
	keepassxc
	kitty
	libreoffice
	lmms
	macfuse
