install_formula() {
	local name=$1
	if brew list --formula "$name" &>/dev/null; then
		echo "$name already installed"
	else
		brew install "$name"
	fi
}

install_cask() {
	local name=$1
	if brew list --cask "$name" &>/dev/null; then
		echo "$name already installed"
	else
		brew install --cask "$name"
	fi
}

for t in "${taps[@]}"; do
	brew tap "$t"
done

for f in "${formulae[@]}"; do
	install_formula "$f"
done

for c in "${casks[@]}"; do
	install_cask "$c"
done
