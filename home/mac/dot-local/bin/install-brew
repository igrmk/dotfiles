	python@3.11
	qpdf
	resvg
	riff
	ripgrep
	rlwrap
	ruff
	rust
	s3cmd
	samba
	sd
	shellcheck
	shntool
	socat
	sponge
	stern
	stow
	tectonic
	telnet
	terraform
	texlive
	tidy-html5
	tmux
	tree-sitter-cli
	uv
	verapdf
	vim
	watch
	wget
	wireguard-tools
	xmlstarlet
