#!/usr/bin/env bash
# Install the Homebrew formulae and casks kept on this machine.
# brew skips anything already present, so re-run any time to fill in what's missing.
# Regenerate these lists on a fully set-up machine with:
#   brew leaves --installed-on-request   # top-level formulae
#   brew list --cask                     # casks
# The Docker stack (colima, docker, docker-buildx) is listed here too, but
# install-colima additionally wires the buildx plugin, so run that afterwards.
set -euo pipefail

# Third-party taps required by some items below.
# Other taps seen on this machine but with nothing installed from them:
# charmbracelet/tap, dart-lang/dart, sass/sass, stripe/stripe-cli.
taps=(
	isen-ng/dotnet-sdk-versions   # dotnet-sdk* casks
	mongodb/brew                  # mongosh
)

formulae=(
	agg
	argyll-cms
	asciinema
	automake
