# vim: filetype=gitconfig

[core]
   excludesfile = ~/.config/git/ignore
   filemode = true
   autocrlf = false
   editor = vi
   abbrev = 8
[color]
   diff = auto
   status = auto
   branch = auto
[alias]
   st = status
   st-no-designer = status -- ':!*.Designer.cs'
   st-no-vendor = status -- ':!vendor'
   stashes = stash list --format='%gd %cs: %gs'
   sw = switch
   swd = switch --detach
   rrrd = -c core.pager=delta restore
   rrrd1 = -c delta.side-by-side=false rrrd
   rrr = rrrd

   diff = diff --find-copies --patience

   d-no-designer = d -- ':!*.Designer.cs'
   d-no-vendor = d -- ':!vendor'
   dc-no-designer = dc -- ':!*.Designer.cs'
   dc-no-vendor = dc -- ':!vendor'

   ddt = !git difftool --dir-diff --tool=difftastic
   dcdt = ddt --cached

   dk = !git difftool --dir-diff --tool=kdiff3
   dck = dk --cached

   dm = !git difftool --dir-diff --tool=meld
   dcm = dm --cached

   dt  = difftool
   dtc = dt --cached

   dw  = diff --find-copies --patience --color-words
   dcw = dw --cached

   dd  = -c core.pager=delta diff --find-copies --patience
   dcd = dd --cached
   dd1 = -c delta.side-by-side=false dd
   dcd1 = -c delta.side-by-side=false dcd

   dr  = -c core.pager=riff diff --find-copies --patience
   dcr = dr --cached

   # default
   d = dd
   d1 = dd1
   dc = d --cached
   dc1 = d1 --cached
   sh = showd

   lp-no-designer = log -p -M -- ':!*.Designer.cs'
   lpdt  = "!GIT_EXTERNAL_DIFF=difft git log -p -M --ext-diff"
   lpd = -c core.pager=delta log -p -M
   lpd1 = -c delta.side-by-side=false lpd
   lpr = -c core.pager=riff log -p -M
   glog = log --graph --oneline --pretty=fuller --author-date-order
   gloga = glog --all
   lp = lpd
   lp1 = lpd1

   showd = -c core.pager=delta show
   showd1 = -c delta.side-by-side=false showd

   overview = log --graph --oneline --pretty=fuller --author-date-order --all --simplify-by-decoration
   dry = commit --dry-run -a
   unamend = reset --soft HEAD@{1}
   unmerge = git reset --hard ORIG_HEAD
   get-submodules = submodule update --init --recursive
   squash-all = "!f(){ [ ! -z \"$1\" ] && git reset $(git commit-tree HEAD^{tree} -m \"$1\"); };f"
   stash-unstaged = "!f() { cd ${GIT_PREFIX:-./}; git stash push --keep-index --include-untracked -- $(git ls-files --modified --others --exclude-standard); }; f"
   bz = "!f() { cd ${GIT_PREFIX:-./}; echo -- $(git ls-files --modified --others --exclude-standard); }; f"
   conflicts = diff --name-only --diff-filter=U
   force-clean-all = clean -fdx
   untrack = rm --cached
   pushf = push --force-with-lease --force-if-includes
[user]
   name = Igor Mikushkin
   email = igor.mikushkin@gmail.com
[diff]
   colorMoved = default
   colorMovedWs = allow-indentation-change
   tool = kdiff3
   pager = less -SFXM +Gg
[difftool]
   prompt = false
[push]
   default = current
   autoSetupRemote = true
   followTags = true
[mergetool]
   prompt = false
   keepBackup = false
   keepTemporaries = false
[merge]
   tool = kdiff3
[log]
   abbrevCommit = true
   decorate = true
   follow = true
[init]
   defaultBranch = main
[tag]
   sort = -version:refname
[difftool "kdiff3"]
   cmd = kdiff3 --cs FullAnalysis=1 --cs ShowLineNumbers=1 --cs SkipDirStatus=1 --cs FollowDirLinks=1 --cs FollowFileLinks=1 "$LOCAL" "$REMOTE"
[difftool "difftastic"]
   cmd = difft "$LOCAL" "$REMOTE"
[diff "hex"]
   textconv = hexdump -v -C
   binary = true
[delta]
   syntax-theme              = None
   side-by-side              = true
   navigate                  = false

   # Remap git's color-moved ANSI (defaults: bold magenta/blue/cyan/yellow) to chosen colors in delta.
   # Done here rather than via color.diff.*Moved on the suspicion
   # that delta's matcher may handle git's defaults more reliably than custom hex.
   # At least, you can't set color.diff.*Moved to plain red/green — delta can't tell them from regular added/removed lines.
   map-styles                = bold magenta => white "#545557", \
                               bold blue    => white "#545557", \
                               bold cyan    => white "#545557", \
                               bold yellow  => white "#545557"

   # The minus/plus background colours below are tuned to equal OKLab L ≈ 0.76,
   # so neither feels visually heavier.
   minus-style               = black "#d6a29f"
   minus-emph-style          = bold black "#d6a29f"
   minus-non-emph-style      = white "#545557"
   plus-style                = black "#90c08e"
   plus-emph-style           = bold black "#90c08e"
   plus-non-emph-style       = white "#545557"

   # The line number colors below are the minus/plus background colors with
   # OKLab lightness raised by 0.1 and chroma raised by 0.005.
   line-numbers-minus-style  = "#fbc0bd"
   line-numbers-plus-style   = "#ade1ab"
   line-numbers-zero-style   = "#c0c0c0"
   wrap-left-symbol          = ░
   wrap-right-symbol         = ░
   wrap-right-prefix-symbol  = ░
   inline-hint-style         = white
   line-numbers-left-format  = "{nm:>} "
   line-numbers-right-format = "{np:>} "
   tabs                      = 4
   wrap-word-lookback        = 40

# Must be last to override earlier settings
[include]
   path = os
   path = local

